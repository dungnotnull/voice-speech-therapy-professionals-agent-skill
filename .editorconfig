root = true

[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
end_of_line = lf

[*.{py,pyi}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
indent_size = 4
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
