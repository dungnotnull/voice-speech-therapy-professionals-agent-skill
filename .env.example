# voice-speech-therapy-professionals — Environment Configuration
# Copy this file to .env and fill in values as needed.

# --- API Configuration ---
# Semantic Scholar API key (optional; enables higher rate limits)
# Get one at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ArXiv API base URL (rarely needs changing)
ARXIV_BASE_URL=https://export.arxiv.org/api/query

# Semantic Scholar API base URL
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1/paper/search

# --- Knowledge Base ---
# Path to SECOND-KNOWLEDGE-BRAIN.md (defaults to project root)
BRAIN_PATH=

# --- Network & Retry ---
# Maximum number of retries for failed API requests
MAX_RETRIES=3

# Base delay between retries in seconds (exponential backoff: delay * 2^attempt)
RETRY_BASE_DELAY=2.0

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Rate limit: maximum requests per second per API source
RATE_LIMIT_RPS=3.0

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: text (human-readable) or json (structured)
LOG_FORMAT=text

# --- Scoring ---
# Recency window in days for score calculation (score decays to 0 after this)
RECENCY_WINDOW_DAYS=730

# Citation normalization ceiling (papers with >= this many citations get max score)
CITATION_CEILING=1000

# --- Pipeline ---
# Maximum results fetched per external source (ArXiv, Semantic Scholar)
MAX_RESULTS_PER_SOURCE=10

# Maximum new entries appended per pipeline run
MAX_NEW_ENTRIES_PER_RUN=20
